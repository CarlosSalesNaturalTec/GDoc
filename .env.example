# GDoc — configuração por variáveis de ambiente (12-factor)
# Copie para .env e ajuste. Em produção estes valores vêm do Secret Manager
# (ver infra/terraform e apps/api/src/ports/secrets-port.ts).

# --- Geral ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# --- DatabasePort (Postgres — mesmo em dev e prod) ---
DATABASE_URL=postgres://gdoc_dev:gdoc_dev@127.0.0.1:5432/gdoc_dev
DATABASE_SSL=false

# --- StoragePort ---
# STORAGE_DRIVER: "gcs" (prod) ou "fake-gcs" (dev, aponta para o emulador local)
STORAGE_DRIVER=fake-gcs
STORAGE_BUCKET=gdoc-dev-bucket
# Usado apenas quando STORAGE_DRIVER=fake-gcs
STORAGE_EMULATOR_HOST=http://127.0.0.1:4443
# Projeto GCP (obrigatório em prod; qualquer valor não vazio em dev)
GCP_PROJECT_ID=gdoc-dev
# Caminho para a chave de conta de serviço usada para ASSINAR URLs.
# Em dev: chave dummy gerada pelo SessionStart hook (scripts/session-start.sh).
# Em prod: injetada via Secret Manager / Workload Identity.
STORAGE_SIGNER_KEY_PATH=./.dev/fake-gcs-signer-key.json
STORAGE_SIGNER_CLIENT_EMAIL=dev-signer@gdoc-dev.iam.gserviceaccount.com

# TTLs das URLs assinadas (segundos)
SIGNED_URL_VIEW_TTL_SECONDS=300
SIGNED_URL_DOWNLOAD_TTL_SECONDS=1800

# Cota de armazenamento por pessoa (bytes) — 10 GB
STORAGE_QUOTA_BYTES_PER_USER=10737418240

# --- SecretsPort ---
# SECRETS_DRIVER: "env" (dev) ou "secret-manager" (prod)
SECRETS_DRIVER=env

# --- AuthPort ---
# Parâmetros do hash argon2 (esqueleto; sem telas/CRUD nesta mudança)
AUTH_ARGON2_MEMORY_COST=19456
AUTH_ARGON2_TIME_COST=2
AUTH_ARGON2_PARALLELISM=1
# Segredo de sessão/JWT — em prod vem do Secret Manager
AUTH_SESSION_SECRET=dev-only-insecure-secret-change-me

# --- Pub/Sub (reconciliação de cota pós-upload) ---
# Em dev não há Pub/Sub real; a reconciliação é acionada via endpoint HTTP
# de notificação (POST /internal/storage-events) chamado manualmente/por teste.
PUBSUB_STORAGE_EVENTS_TOPIC=gdoc-storage-finalize
PUBSUB_STORAGE_EVENTS_SUBSCRIPTION=gdoc-storage-finalize-sub

# --- Somente produção (preenchidas pelo Terraform / Cloud Run) ---
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
# GCS_SIGNER_SERVICE_ACCOUNT=api-runtime@<project>.iam.gserviceaccount.com
